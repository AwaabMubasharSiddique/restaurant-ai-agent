# ============================================================
#  Restaurant Customer-Service AI — environment variables
#  Copy to ".env" and fill in. NEVER commit your real .env.
# ============================================================

# --- OpenAI (API key is read from the environment only) ---
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Supabase ---
# Use the service_role key on the server so inserts bypass RLS.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
# If these are left blank the app falls back to an in-memory store
# so you can run the whole demo with no external database.

# --- Reservation capacity (real table-level booking) ---
# Table inventory is set in config.py (RESTAURANT_TABLES); each booking is
# assigned a table that fits the party. Parties bigger than the largest table
# are handed to staff. Override the inventory via env as JSON if you like, e.g.
# RESTAURANT_TABLES=[{"id":"T1","seats":4},{"id":"T2","seats":4},{"id":"T3","seats":8}]
# How long a table is held per booking (minutes); a 7:00 booking blocks 8:00.
SEATING_DURATION_MINUTES=90
RESERVATION_SLOT_MINUTES=30
OPENING_TIME=11:00
CLOSING_TIME=22:00
# Minutes after creating a reservation that a customer can still self-reschedule.
RESERVATION_EDIT_WINDOW_MINUTES=30
# Furthest ahead (in days) a reservation can be booked.
MAX_ADVANCE_DAYS=30

# --- RAG ---
DATA_PATH=data/restaurant_info.txt
FAISS_INDEX_PATH=rag/faiss_index
RETRIEVAL_K=4

# --- Agent ---
# Below this classifier confidence the message is treated as "other"
# and handed off to a human.
LOW_CONFIDENCE_THRESHOLD=0.6

# --- API ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT=20/minute
RESTAURANT_NAME=The Olive Branch
